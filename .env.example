# API URL (Modal deployment)
MODAL_API_URL=https://your-app-name.modal.run

# Frontend (Vite reads variables prefixed with VITE_)
VITE_API_URL=https://your-app-name.modal.run

# LLM Provider: "groq" or "gemini"
LLM_PROVIDER=groq

# Groq (provider=groq)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=qwen/qwen3-32b

# Gemini / Gemma (provider=gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemma-4-26b-a4b-it

# HuggingFace (cross-encoder reranker)
HF_TOKEN=your_huggingface_token_here

# Scraping (Firecrawl)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here